HEADERS={"User-Agent":"Mozilla/5.0"}
KAGGLE_KEY=your_kaggle_api_key
KAGGLE_USERNAME=your_kaggle_username
HF_TOKEN=your_hugging_face_token
GDRIVE_MODEL_FOLDER_ID=your_google_drive_model_folder_id

# API URLs used by the Streamlit dashboard.
# In Cloud Run set both values to your deployed API URL.
API_URL=https://your-api-service-url.run.app
API_URL_LOCAL=http://127.0.0.1:8000

# Local development: sqlite:///./predictions.db
# Production: postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=sqlite:///./predictions.db

# Comma-separated list of allowed origins for FastAPI CORS.
# For a quick test use *, then lock to your Streamlit URL in production.
CORS_ALLOWED_ORIGINS=*

# Cloud Run / Artifact Registry settings
LOCATION=europe-west1
PROJECT_ID=your-gcp-project-id
REPOSITORY=your-artifact-registry-repository
IMAGE=mental-health
PORT=8080
