FROM python:3.11-slim

WORKDIR /app
ENV PYTHONPATH=/app

COPY requirements.dashboard.txt .
RUN pip install --no-cache-dir -r requirements.dashboard.txt

COPY src/ ./src/

EXPOSE 8501
CMD ["sh", "-c", "streamlit run src/dashboard/app.py --server.headless true --server.port ${PORT:-8501} --server.address 0.0.0.0"]
